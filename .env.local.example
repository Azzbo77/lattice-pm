# ── Lattice PM — Local Development Environment ────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.
#
# IMPORTANT: Vite environment variables must be prefixed with VITE_
# They are baked into the JS bundle at BUILD TIME — not runtime.

# URL of your PocketBase instance (no trailing slash)
# Local dev default:
VITE_PB_URL=http://127.0.0.1:8090

# Production default (via nginx proxy, set as Docker build ARG not here):
# VITE_PB_URL=/pb
